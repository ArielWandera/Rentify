APP_NAME=Rentify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (production)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rentify
DB_USERNAME=postgres
DB_PASSWORD=

# SQLite (quick local dev — change DB_CONNECTION to sqlite and remove the others)
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# local = serve from storage/app/public, s3 = Cloudflare R2 / AWS S3
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Gmail SMTP
# Generate an App Password at myaccount.google.com/apppasswords (requires 2FA on Gmail)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# S3-compatible storage — Cloudflare R2 (recommended, free tier) or AWS S3
# Only needed when FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=                          # Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google OAuth — create credentials at console.cloud.google.com
# 1. New project → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# 2. Add Authorised redirect URI: APP_URL/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pesapal Mobile Money — Uganda (MTN MoMo, Airtel Money, Visa/Mastercard)
# 1. Register at https://pesapal.com and get sandbox keys from the developer portal
# 2. Set the variables below, then call POST /api/payments/pesapal/register-ipn once as admin
# 3. Copy the returned ipn_id into PESAPAL_IPN_ID
# 4. Switch PESAPAL_SANDBOX=false and update PESAPAL_CALLBACK_URL when going live
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=
PESAPAL_SANDBOX=true
PESAPAL_CALLBACK_URL=http://localhost:5173/my-rental

# Admin account — seeded on first migrate:seed (change before going live)
ADMIN_EMAIL=admin@rentify.pro
ADMIN_PASSWORD=Password1!
ADMIN_NAME=Admin

# Sentry error tracking — get DSN from sentry.io (free tier works)
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"
# Show demo login panel on the login page — set false in production
VITE_SHOW_DEMO_HINT=true
